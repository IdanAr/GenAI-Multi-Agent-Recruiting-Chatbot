# --- Course materials & instructions (NOT part of the deliverable) ---
# 15 MB of lecture content: large binaries (pptx/pdf/mp3/wav), nested .git
# repos, and course .env files that contain API keys. Kept local only.
Materials/
Instructions/

# NOTE: data/tech.db (the SQLite scheduling DB) is intentionally NOT ignored.
# It is committed so recruiter availability is reproducible across clones.
# Transient SQLite lock/journal sidecar files should not be committed.
data/tech.db-journal
data/tech.db-wal
data/tech.db-shm

# --- Unit test suite (kept local only; test_evals.ipynb is the required deliverable) ---
# The brief's "must have" list only requires tests/test_evals.ipynb. These
# module-level unit tests were built via TDD during development and are kept
# on disk for local verification, but are not part of the submitted project.
tests/test_embedding.py
tests/test_evaluation.py
tests/test_exit_advisor.py
tests/test_info_advisor.py
tests/test_main.py
tests/test_main_agent.py
